# Postgres connection string (TimescaleDB-enabled instance)
DATABASE_URL=postgres://postgres:smartsolar@localhost:5433/smartsolarems

# HTTP server port
PORT=8080

# Session signing secret. Optional: auto-generated at boot if absent
# (regenerating it invalidates existing sessions).
SESSION_SECRET=

# IANA timezone used for scheduling/planning (5-min slot alignment, day boundaries)
TZ=Australia/Sydney
